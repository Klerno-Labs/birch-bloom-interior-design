# Birch & Bloom - Environment Variables
# Copy this file to .env.local and fill in the values

# Next.js
NEXT_PUBLIC_SITE_URL=https://birchandbloom.com

# Contact Form (Example: Resend, SendGrid, or Nodemailer config)
# If using a 3rd party email service API, place keys here.
# CONTACT_API_KEY=your_api_key_here

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX